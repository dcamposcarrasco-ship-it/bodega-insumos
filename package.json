{
  "name": "bodega-insumos",
  "version": "2.3.1",
  "description": "Bodega de Insumos — Sala Toma de Muestras",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "build-installer": "electron-builder --win nsis",
    "release": "electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.bodega.insumos",
    "productName": "Bodega Insumos STM",
    "afterPack": "./afterPack.js",
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "icon.ico",
      "signAndEditExecutable": false
    },
    "publish": {
      "provider": "github",
      "owner": "dcamposcarrasco-ship-it",
      "repo": "bodega-insumos",
      "releaseType": "release"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    },
    "files": [
      "main.js",
      "index.html",
      "preload.js",
      "icon.ico"
    ]
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {}
}
