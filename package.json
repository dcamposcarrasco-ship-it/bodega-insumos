{
  "name": "bodega-insumos",
  "version": "2.0.0",
  "description": "Bodega de Insumos — Sala Toma de Muestras",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "build-installer": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.bodega.insumos",
    "productName": "Bodega Insumos STM",
    "win": {
      "target": ["portable", "nsis"],
      "icon": "icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "main.js",
      "index.html",
      "preload.js"
    ]
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1"
  }
}
